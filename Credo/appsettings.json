{
  "ConnectionStrings": {
    "__comment": "Templates resolved at runtime by DbContextFactory: [ServerName] -> {MachineName}\\SQL, [DatabaseName] -> appConfig.DbName. User Secrets / env vars override these for credentials.",
    "ROG": "Server=[ServerName];Database=[DatabaseName];Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True",
    "XPS": "Server=[ServerName];Database=[DatabaseName];Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True",
    "Local": "Server=[ServerName];Database=[DatabaseName];Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "DetailedErrors": true,
  "Paths": {
    "Backup": "%USERPROFILE%\\OneDrive\\Database\\SQL16\\Backup\\Credo\\",
    "Downloads": "%USERPROFILE%\\Downloads\\Credo\\",
    "BrowserXPS": "%ProgramFiles%\\Google\\Chrome\\Application\\chrome.exe",
    "BrowserROG": "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5123"
      }
      //"Https": {
      //  "Url": "https://localhost:5001"
      //}
    }
  },
  "AllowedHosts": "*"
}
