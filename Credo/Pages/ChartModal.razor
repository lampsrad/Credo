@inject Credo.Services.GraphService graph
@inject Microsoft.JSInterop.IJSRuntime jsr
@using Credo.Services

<div class="chart-modal-backdrop" @onclick="Close">
    <div class="chart-modal-dialog" @onclick:stopPropagation>
        <div class="chart-modal-header">
            <span class="chart-modal-title">@(Chart?.Title ?? "")</span>
            <div class="portfolio-toolbar" style="padding:0; margin:0; justify-content:flex-end;">
                <button class="btn-refresh btn-refresh-mini @(show50 ? "btn-active" : "")"
                        @onclick="Toggle50" title="Toggle 50-day moving average">50 DMA</button>
                <button class="btn-refresh btn-refresh-mini @(show200 ? "btn-active" : "")"
                        @onclick="Toggle200" title="Toggle 200-day moving average">200 DMA</button>
                <button class="btn-refresh btn-refresh-mini"
                        @onclick="TogglePct" title="Toggle % change view">@range</button>
                <button class="chart-modal-close" @onclick="Close" title="Close">✕</button>
            </div>
        </div>
        <div style="position:relative; aspect-ratio: 16 / 9; max-height:80vh; width:@(Width > 0 ? Width + "px" : "min(900px,88vw)"); background:#1a1d1f; border-radius:6px; padding:0.5rem;">
            <canvas id="chartModalCanvas"></canvas>
        </div>
    </div>
</div>

@code {
    [Parameter] public ChartData? Chart { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public int Width { get; set; }

    private string range = "Percentage";
    private ChartData? visibleChart;
    private bool chartRendered;
    private bool isPct = true;
    private bool show50;
    private bool show200;

    protected override void OnParametersSet()
    {
        if (Chart is not null)
        {
            visibleChart = Chart;
            chartRendered = false;
            show50 = false;
            show200 = false;
        }
    }

    private async Task TogglePct()
    {
        isPct = !isPct;
        range = isPct ? "Percentage" : "Price";
        await jsr.InvokeVoidAsync("toggleSecurityChartPct");
    }

    private async Task Toggle50()
    {
        show50 = await jsr.InvokeAsync<bool>("toggleMA50");
    }

    private async Task Toggle200()
    {
        show200 = await jsr.InvokeAsync<bool>("toggleMA200");
    }

    private async Task Close()
    {
        if (OnClose.HasDelegate)
            await OnClose.InvokeAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (visibleChart is not null && !chartRendered)
        {
            chartRendered = true;
            await jsr.InvokeVoidAsync("renderSecurityChart", "chartModalCanvas",
                visibleChart.Labels, visibleChart.Data, visibleChart.SpyData,
                visibleChart.Title, visibleChart.TradeData, visibleChart.SellTradeData, isPct);
        }
    }
}
